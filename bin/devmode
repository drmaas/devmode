#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEVMODE_HOME="${DEVMODE_HOME:-$(cd "${SCRIPT_DIR}/.." && pwd)}"
MODE_HELPER="${DEVMODE_HOME}/bin/dm"

die() {
  echo "Error: $*" >&2
  exit 1
}

usage() {
  cat <<'EOF'
Usage:
  devmode install [target-directory]
  devmode uninstall [target-directory]
  devmode uninstall --global
  devmode hook inject-mode
  devmode hook ensure-mode
  devmode mode current
  devmode mode status
  devmode mode list
  devmode mode set <og|tdd|vibe|poc|sdd|brainstorm|oneoff>
  devmode mode explain <og|tdd|vibe|poc|sdd|brainstorm|oneoff>
  devmode current
  devmode status
  devmode list
  devmode set <mode>
  devmode explain <mode>
  devmode help

Examples:
  devmode install .
  devmode uninstall .
  devmode uninstall --global
  devmode mode set og
  devmode status
  devmode hook inject-mode
EOF
}

require_mode_helper() {
  [[ -x "${MODE_HELPER}" ]] || die "Mode helper not found at ${MODE_HELPER}"
}

merge_hook_settings() {
  local settings_file="$1"

  command -v python3 >/dev/null 2>&1 || die "python3 is required for devmode install"

  python3 - "${settings_file}" <<'PY'
import json
import os
import sys

settings_file = sys.argv[1]

if os.path.exists(settings_file):
    with open(settings_file, "r", encoding="utf-8") as handle:
        data = json.load(handle)
else:
    data = {}

hooks = data.setdefault("hooks", {})
required = {
    "SessionStart": "devmode hook inject-mode",
    "UserPromptSubmit": "devmode hook ensure-mode",
}

for event_name, command in required.items():
    groups = hooks.setdefault(event_name, [])
    already_present = False
    for group in groups:
        for hook in group.get("hooks", []):
            if hook.get("type") == "command" and hook.get("command") == command:
                already_present = True
                break
        if already_present:
            break

    if not already_present:
        groups.append(
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": command,
                    }
                ]
            }
        )

os.makedirs(os.path.dirname(settings_file), exist_ok=True)
with open(settings_file, "w", encoding="utf-8") as handle:
    json.dump(data, handle, indent=2)
    handle.write("\n")
PY
}

remove_hook_settings() {
  local settings_file="$1"

  command -v python3 >/dev/null 2>&1 || die "python3 is required for devmode uninstall"

  python3 - "${settings_file}" <<'PY'
import json
import os
import sys

settings_file = sys.argv[1]

if not os.path.exists(settings_file):
    raise SystemExit(0)

with open(settings_file, "r", encoding="utf-8") as handle:
    data = json.load(handle)

required = {
    "SessionStart": "devmode hook inject-mode",
    "UserPromptSubmit": "devmode hook ensure-mode",
}

hooks = data.get("hooks")
if isinstance(hooks, dict):
    for event_name, command in required.items():
        groups = hooks.get(event_name, [])
        updated_groups = []
        for group in groups:
            hook_list = group.get("hooks", [])
            filtered_hooks = [
                hook
                for hook in hook_list
                if not (
                    hook.get("type") == "command"
                    and hook.get("command") == command
                )
            ]

            if filtered_hooks:
                updated_group = dict(group)
                updated_group["hooks"] = filtered_hooks
                updated_groups.append(updated_group)

        if updated_groups:
            hooks[event_name] = updated_groups
        else:
            hooks.pop(event_name, None)

    if not hooks:
        data.pop("hooks", None)

if data:
    with open(settings_file, "w", encoding="utf-8") as handle:
        json.dump(data, handle, indent=2)
        handle.write("\n")
else:
    os.remove(settings_file)
PY
}

cleanup_empty_dirs() {
  local dir
  for dir in "$@"; do
    if [[ -d "${dir}" ]]; then
      rmdir "${dir}" 2>/dev/null || true
    fi
  done
}

install_project_assets() {
  local target_dir="${1:-.}"
  local claude_dir
  local instruction_target

  [[ -d "${target_dir}" ]] || die "Target directory does not exist: ${target_dir}"

  target_dir="$(cd "${target_dir}" && pwd)"
  claude_dir="${target_dir}/.claude"

  mkdir -p "${claude_dir}/skills" "${claude_dir}/agents" "${claude_dir}/commands" "${claude_dir}/rules"

  rm -rf "${claude_dir}/commands/devmode"
  rm -f "${claude_dir}/agents/devmode-builder.md" "${claude_dir}/agents/devmode-reviewer.md"

  shopt -s nullglob
  local skill_dir
  for skill_dir in "${claude_dir}"/skills/devmode-*; do
    rm -rf "${skill_dir}"
  done
  shopt -u nullglob

  cp -R "${DEVMODE_HOME}/skills/." "${claude_dir}/skills/"
  cp -R "${DEVMODE_HOME}/agents/." "${claude_dir}/agents/"
  cp -R "${DEVMODE_HOME}/commands/." "${claude_dir}/commands/"

  if [[ -f "${target_dir}/CLAUDE.md" ]]; then
    cp "${DEVMODE_HOME}/templates/devmode-rule.md" "${claude_dir}/rules/devmode.md"
    instruction_target=".claude/rules/devmode.md"
  else
    cp "${DEVMODE_HOME}/templates/CLAUDE.md" "${target_dir}/CLAUDE.md"
    rm -f "${claude_dir}/rules/devmode.md"
    instruction_target="CLAUDE.md"
  fi

  merge_hook_settings "${claude_dir}/settings.json"

  cat <<EOF
Installed devmode into ${target_dir}
- command: .claude/commands/devmode/dm.md
- skills: .claude/skills/devmode-*
- agents: .claude/agents/devmode-*.md
- hooks: .claude/settings.json
- instructions: ${instruction_target}
EOF
}

uninstall_project_assets() {
  local target_dir="${1:-.}"
  local claude_dir
  local settings_file

  [[ -d "${target_dir}" ]] || die "Target directory does not exist: ${target_dir}"

  target_dir="$(cd "${target_dir}" && pwd)"
  claude_dir="${target_dir}/.claude"
  settings_file="${claude_dir}/settings.json"

  rm -rf "${claude_dir}/commands/devmode"
  rm -f \
    "${claude_dir}/agents/devmode-builder.md" \
    "${claude_dir}/agents/devmode-reviewer.md" \
    "${claude_dir}/rules/devmode.md"

  shopt -s nullglob
  local skill_dir
  for skill_dir in "${claude_dir}"/skills/devmode-*; do
    rm -rf "${skill_dir}"
  done
  shopt -u nullglob

  if [[ -f "${settings_file}" ]]; then
    remove_hook_settings "${settings_file}"
  fi

  if [[ -f "${target_dir}/CLAUDE.md" ]] && cmp -s "${target_dir}/CLAUDE.md" "${DEVMODE_HOME}/templates/CLAUDE.md"; then
    rm -f "${target_dir}/CLAUDE.md"
  fi

  cleanup_empty_dirs \
    "${claude_dir}/commands/devmode" \
    "${claude_dir}/commands" \
    "${claude_dir}/skills" \
    "${claude_dir}/agents" \
    "${claude_dir}/rules" \
    "${claude_dir}"

  cat <<EOF
Uninstalled devmode from ${target_dir}
- removed: .claude/commands/devmode
- removed: .claude/skills/devmode-*
- removed: .claude/agents/devmode-*.md
- removed: .claude/rules/devmode.md
- cleaned: .claude/settings.json devmode hooks
- removed generated CLAUDE.md only if it exactly matched the devmode template
EOF
}

uninstall_global() {
  local share_dir="${DEVMODE_HOME:-}"
  local bin_path="${DEVMODE_BIN_PATH:-}"

  [[ -n "${share_dir}" ]] || die "Global uninstall requires DEVMODE_HOME. Run the installed 'devmode' wrapper or use './install.sh uninstall'."
  [[ -d "${share_dir}" ]] || die "Global install directory not found: ${share_dir}"

  if [[ -n "${bin_path}" ]]; then
    rm -f "${bin_path}"
  fi
  rm -rf "${share_dir}"

  cat <<EOF
Removed global devmode installation
- binary: ${bin_path:-unknown}
- home:   ${share_dir}
EOF
}

current_mode() {
  require_mode_helper
  "${MODE_HELPER}" current || true
}

cmd_hook_inject_mode() {
  local mode
  local desc
  local guidelines
  local workflow

  mode="$(current_mode)"

  if [[ -z "${mode}" ]]; then
    cat <<'EOF'
[devmode] No development mode is set.
Run `/devmode:dm` to pick a mode before starting work.
EOF
    return
  fi

  case "${mode}" in
    og)
      guidelines="$(cat <<'GUIDE'
### og Guidelines
1. Confirm requirements and constraints before coding.
2. Sketch a lightweight plan before coding: touched surfaces, change order, and validation.
3. Load planning-oriented skills only when task complexity justifies it.
4. Implement in small, reviewable increments.
5. Run required quality gates after implementation (type/static checks, lint/format, tests).
6. Fix regressions before handoff and request review with a concise summary.
GUIDE
)"
      desc="light plan -> implement -> verify -> review"
      workflow="$(cat <<'WORK'
When the user asks you to do implementation work, delegate to the **devmode-builder** subagent - it owns the full execution loop (analyze -> make a lightweight plan -> load skills as needed -> implement -> validate -> hand off for review). Do not do implementation yourself; let the builder run it.

When implementation is ready for review, the builder will delegate to **devmode-reviewer**, which issues a verdict (Approve / Approve with suggestions / Request changes) and returns control to the builder if changes are needed.

You do not need to invoke these agents manually - use them as subagents when tasks arrive.
WORK
)"
      ;;
    tdd)
      guidelines="$(cat <<'GUIDE'
### tdd Guidelines
1. Start by writing a failing test that captures one behavior.
2. Implement the minimum code needed to pass that test.
3. Refactor only after tests are green.
4. Repeat in tight red/green/refactor cycles.
5. Keep tests behavior-focused and run full required gates before handoff.
GUIDE
)"
      desc="tests-first (red/green/refactor)"
      workflow="$(cat <<'WORK'
When the user asks for implementation, delegate to **devmode-builder**. In this mode the builder writes a failing test first, implements to green, then hands off to **devmode-reviewer**.

You do not need to invoke these agents manually - use them as subagents when tasks arrive.
WORK
)"
      ;;
    vibe)
      guidelines="$(cat <<'GUIDE'
### vibe Guidelines
1. Prioritize speed and feedback loops over ceremony.
2. Keep changes scoped so they can be validated quickly.
3. Maintain basic safety checks (at least targeted tests or smoke validation before handoff).
4. Document shortcuts or deferred hardening work explicitly.
5. Before merging, ensure follow-up work is tracked if full quality gates were deferred.
GUIDE
)"
      desc="fast iteration with reduced ceremony"
      workflow="$(cat <<'WORK'
When the user asks you to do implementation work, delegate to the **devmode-builder** subagent. The builder should move quickly, keep scope tight, and still hand off to **devmode-reviewer** before final delivery.

You do not need to invoke these agents manually - use them as subagents when tasks arrive.
WORK
)"
      ;;
    poc)
      guidelines="$(cat <<'GUIDE'
### poc Guidelines
1. Optimize for learning and risk reduction, not production readiness.
2. Prefer the simplest implementation that proves or disproves the idea.
3. Timebox exploration and capture explicit success/failure criteria.
4. Document assumptions, known gaps, and what would be required for productionization.
5. Do not ship POC code to production paths without a follow-up hardening pass.
GUIDE
)"
      desc="exploratory spike, not production-ready"
      workflow="$(cat <<'WORK'
When the user asks you to explore or prototype, delegate to **devmode-builder**. The builder should optimize for learning, keep the work clearly non-production, and still use **devmode-reviewer** if code changes are produced.

You do not need to invoke these agents manually - use them as subagents when tasks arrive.
WORK
)"
      ;;
    sdd)
      guidelines="$(cat <<'GUIDE'
### sdd Guidelines
1. Capture requirements, constraints, non-goals, and acceptance criteria.
2. Draft a concise spec (scope, contracts, edge cases, validation strategy).
3. Build an ordered implementation plan with dependencies.
4. Decompose into atomic tasks with explicit completion criteria.
5. Keep exactly one task in progress.
6. Maintain traceability from each change back to a requirement.
GUIDE
)"
      desc="spec-driven development"
      workflow="$(cat <<'WORK'
When the user asks for implementation, delegate to **devmode-builder**. In this mode the builder should follow the full spec-driven loop before coding, then hand off to **devmode-reviewer**.

You do not need to invoke these agents manually - use them as subagents when tasks arrive.
WORK
)"
      ;;
    brainstorm)
      guidelines="$(cat <<'GUIDE'
### brainstorm Guidelines
1. Focus on framing the problem, generating options, and comparing tradeoffs.
2. Explore concrete approaches, constraints, risks, and likely implementation shapes.
3. Produce sketches, recommendations, or lightweight plans without editing files.
4. Stay in discussion mode unless the user explicitly switches to an implementation-oriented mode.
5. End with a recommended direction or a short set of viable options.
GUIDE
)"
      desc="explore ideas without writing code"
      workflow="$(cat <<'WORK'
Do **not** write code, edit files, or delegate to **devmode-builder** in this mode. Stay in ideation, planning, architecture discussion, and tradeoff analysis.

If the user wants to move from ideation to execution, have them switch to an implementation-oriented mode such as `oneoff`, `og`, `tdd`, `vibe`, `poc`, or `sdd`.
WORK
)"
      ;;
    oneoff)
      guidelines="$(cat <<'GUIDE'
### oneoff Guidelines
1. Default to immediate execution of the user's request.
2. Skip heavy planning and ceremony unless ambiguity or risk makes it necessary.
3. Make the smallest coherent change that fully satisfies the ask.
4. Run the minimum appropriate validation for the touched surface.
5. If code changes are made, finish with review before final delivery.
GUIDE
)"
      desc="directly implement the user's request"
      workflow="$(cat <<'WORK'
When the user asks for work, delegate immediately to **devmode-builder**. In this mode the builder should implement directly, avoid unnecessary planning overhead, and hand off to **devmode-reviewer** once the requested change is ready.

You do not need to invoke these agents manually - use them as subagents when tasks arrive.
WORK
)"
      ;;
    *)
      printf '[devmode] Active mode: %s (unrecognized - run /devmode:dm to reset)\n' "${mode}"
      return
      ;;
  esac

  cat <<EOF
[devmode] Active development mode: **${mode}** - ${desc}

${guidelines}

### How to work in this mode

${workflow}

### Skills (used internally by builder and reviewer)
| Skill | When to use |
|-------|-------------|
| devmode-orchestrator | Multi-step or cross-module work |
| devmode-librarian    | Navigating unfamiliar code, tracing data flows |
| devmode-coder        | Core implementation and refactoring |
| devmode-tester       | Writing or updating tests, TDD cycles |
| devmode-gatekeeper   | Pre-handoff quality gate validation |
| devmode-architect    | System design and architectural decisions |
| devmode-code-review  | Full code review methodology (used by reviewer) |

To switch modes, run \`/devmode:dm\`.
EOF
}

cmd_hook_ensure_mode() {
  if [[ -z "$(current_mode)" ]]; then
    echo "[devmode] No development mode is set. Run \`/devmode:dm\` to pick one before continuing." >&2
    exit 2
  fi
}

main() {
  local passthrough_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        passthrough_args+=("$1")
        shift
        ;;
      *)
        break
        ;;
    esac
  done

  local cmd="${1:-help}"
  shift || true

  case "${cmd}" in
    install)
      install_project_assets "${1:-.}"
      ;;
    uninstall)
      if [[ "${1:-}" == "--global" ]]; then
        uninstall_global
      else
        uninstall_project_assets "${1:-.}"
      fi
      ;;
    hook)
      local hook_cmd="${1:-}"
      shift || true
      case "${hook_cmd}" in
        inject-mode) cmd_hook_inject_mode ;;
        ensure-mode) cmd_hook_ensure_mode ;;
        *) die "Unknown hook command '${hook_cmd}'" ;;
      esac
      ;;
    mode)
      require_mode_helper
      "${MODE_HELPER}" "${passthrough_args[@]}" "$@"
      ;;
    current|status|list|set|explain)
      require_mode_helper
      "${MODE_HELPER}" "${passthrough_args[@]}" "${cmd}" "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      die "Unknown command '${cmd}'. Run 'devmode help'."
      ;;
  esac
}

main "$@"
